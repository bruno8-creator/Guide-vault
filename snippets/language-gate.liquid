<div class="language-gate" data-language-gate hidden>
  <div class="language-gate-backdrop"></div>
  <section class="language-gate-panel" aria-labelledby="language-gate-title" role="dialog" aria-modal="true">
    <img class="language-gate-logo" src="{{ 'guide-market-logo.svg' | asset_url }}" alt="Guide Market">
    <p class="eyebrow">Choose your language</p>
    <h2 id="language-gate-title">Select your shopping experience.</h2>
    <p>
      Choose the language for the website. Product pages will automatically select the matching
      English or Spanish version when it is available.
    </p>
    <div class="language-actions">
      <button type="button" class="button" data-language-choice="en">English</button>
      <button type="button" class="button secondary" data-language-choice="es">Español</button>
    </div>
  </section>
</div>

<script>
  window.GuideMarketLanguage = {
    key: 'guideMarketLanguage',
    get: function () {
      try {
        return window.localStorage.getItem(this.key);
      } catch (error) {
        return null;
      }
    },
    set: function (language) {
      try {
        window.localStorage.setItem(this.key, language);
        document.documentElement.setAttribute('data-guide-language', language);
      } catch (error) {}
    }
  };

  document.addEventListener('DOMContentLoaded', function () {
    var gate = document.querySelector('[data-language-gate]');
    var selectedLanguage = window.GuideMarketLanguage.get();

    if (selectedLanguage) {
      document.documentElement.setAttribute('data-guide-language', selectedLanguage);
    } else if (gate) {
      gate.hidden = false;
      document.body.classList.add('language-gate-open');
    }

    document.querySelectorAll('[data-language-choice]').forEach(function (button) {
      button.addEventListener('click', function () {
        var language = button.getAttribute('data-language-choice');
        window.GuideMarketLanguage.set(language);
        if (gate) gate.hidden = true;
        document.body.classList.remove('language-gate-open');
        document.dispatchEvent(new CustomEvent('guide-market-language-change', { detail: { language: language } }));
      });
    });
  });
</script>
