<article class="product-card">
  <a href="{{ product.url }}" class="product-card-media" aria-label="{{ product.title | escape }}">
    {% if product.featured_image %}
      {{
        product.featured_image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          widths: '360, 540, 720, 900',
          sizes: '(min-width: 990px) 30vw, (min-width: 640px) 45vw, 100vw',
          alt: product.featured_image.alt | default: product.title | escape
      }}
    {% else %}
      <div class="product-card-placeholder" aria-hidden="true">
        <span>Guide Market</span>
      </div>
    {% endif %}
  </a>
  <div class="product-card-body">
    <p class="eyebrow">Digital Resource</p>
    <div class="product-card-meta">
      <h3>
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      {% if product.price_varies %}
        <p class="product-price">From {{ product.price_min | money }}</p>
      {% else %}
        <p class="product-price">{{ product.price | money }}</p>
      {% endif %}
    </div>
    <a class="button secondary product-link" href="{{ product.url }}">View details</a>
  </div>
</article>
