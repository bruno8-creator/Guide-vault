<section class="product-page">
  <div class="product-detail">
    <div class="product-gallery">
      {% if product.media.size > 0 %}
        <div class="product-main-media">
          {% for media in product.media %}
            <div class="product-media-item{% if forloop.first %} active{% endif %}" id="Media-{{ media.id }}">
              {% case media.media_type %}
                {% when 'image' %}
                  {% assign media_loading = 'lazy' %}
                  {% if forloop.first %}
                    {% assign media_loading = 'eager' %}
                  {% endif %}
                  {{
                    media
                    | image_url: width: 1400
                    | image_tag:
                      loading: media_loading,
                      widths: '540, 720, 900, 1200, 1400',
                      sizes: '(min-width: 990px) 50vw, 100vw',
                      alt: media.alt | default: product.title | escape
                  }}
                {% when 'video' %}
                  {{ media | video_tag: controls: true, image_size: '1200x' }}
                {% when 'external_video' %}
                  {{ media | external_video_tag }}
                {% when 'model' %}
                  {{ media | model_viewer_tag }}
              {% endcase %}
            </div>
          {% endfor %}
        </div>

        {% if product.media.size > 1 %}
          <div class="product-thumbnails" aria-label="Product media">
            {% for media in product.media %}
              <button
                type="button"
                class="product-thumbnail{% if forloop.first %} active{% endif %}"
                data-media-target="Media-{{ media.id }}"
                aria-label="Show product media {{ forloop.index }}"
              >
                {% if media.preview_image %}
                  {{
                    media.preview_image
                    | image_url: width: 220
                    | image_tag:
                      loading: 'lazy',
                      widths: '120, 180, 220',
                      sizes: '90px',
                      alt: media.alt | default: product.title | escape
                  }}
                {% else %}
                  <span>{{ media.media_type }}</span>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      {% elsif product.featured_image %}
        <div class="product-main-media">
          <div class="product-media-item active">
            {{
              product.featured_image
              | image_url: width: 1200
              | image_tag:
                loading: 'eager',
                widths: '540, 720, 900, 1200',
                sizes: '(min-width: 990px) 50vw, 100vw',
                alt: product.featured_image.alt | default: product.title | escape
            }}
          </div>
        </div>
      {% else %}
        <div class="product-card-placeholder large" aria-hidden="true">
          <span>Guide Market</span>
        </div>
      {% endif %}
    </div>

    <div class="product-detail-content">
      <p class="eyebrow">Guide Market Digital Resource</p>
      <h1>{{ product.title }}</h1>
      {% if product.price_varies %}
        <p class="product-price large">From {{ product.price_min | money }}</p>
      {% else %}
        <p class="product-price large">{{ product.price | money }}</p>
      {% endif %}

      {% form 'product', product, class: 'purchase-panel' %}
        <div class="variant-panel">
          <label for="ProductVariantSelect">Choose version</label>
          <select id="ProductVariantSelect" class="variant-select" name="id">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-available="{{ variant.available }}"
                {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
              >
                {{ variant.title }}{% unless variant.available %} - Unavailable{% endunless %}
              </option>
            {% endfor %}
          </select>
          <p class="variant-help">
            Choose the language/version you want before adding it to cart.
          </p>
        </div>

        <div class="quantity-row">
          <label for="ProductQuantity">Quantity</label>
          <input id="ProductQuantity" type="number" name="quantity" value="1" min="1">
        </div>

        <div class="purchase-actions">
          <button
            id="AddToCartButton"
            class="button buy-button"
            type="submit"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            Add to cart
          </button>
          <a class="button secondary" href="{{ routes.cart_url }}">Go to cart</a>
        </div>

        <div class="dynamic-checkout">
          {{ form | payment_button }}
        </div>

        <p id="VariantAvailability" class="variant-help">
          {% if product.selected_or_first_available_variant.available %}
            Available now.
          {% else %}
            This version is currently unavailable.
          {% endif %}
        </p>
      {% endform %}

      {% if product.description != blank %}
        <div class="rte product-description">
          {{ product.description }}
        </div>
      {% else %}
        <p class="product-description">More details for this digital resource will be added soon.</p>
      {% endif %}

      <div class="product-note">
        <span class="lock">Digital Product</span>
        <p>Digital delivery and checkout settings should be reviewed in Shopify before launch.</p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var select = document.getElementById('ProductVariantSelect');
    var price = document.querySelector('.product-price.large');

    if (select && price) {
      select.addEventListener('change', function () {
        var selected = select.options[select.selectedIndex];
        if (selected && selected.dataset.price) {
          price.textContent = selected.dataset.price;
        }
        var addButton = document.getElementById('AddToCartButton');
        var availability = document.getElementById('VariantAvailability');
        var available = selected && selected.dataset.available === 'true';
        if (addButton) {
          addButton.disabled = !available;
          addButton.textContent = available ? 'Add to cart' : 'Unavailable';
        }
        if (availability) {
          availability.textContent = available ? 'Available now.' : 'This version is currently unavailable.';
        }
      });
    }

    var thumbnails = document.querySelectorAll('[data-media-target]');
    thumbnails.forEach(function (thumbnail) {
      thumbnail.addEventListener('click', function () {
        var targetId = thumbnail.getAttribute('data-media-target');
        var target = document.getElementById(targetId);
        if (!target) return;

        document.querySelectorAll('.product-media-item').forEach(function (item) {
          item.classList.remove('active');
        });
        document.querySelectorAll('.product-thumbnail').forEach(function (item) {
          item.classList.remove('active');
        });

        target.classList.add('active');
        thumbnail.classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product details",
  "settings": []
}
{% endschema %}
