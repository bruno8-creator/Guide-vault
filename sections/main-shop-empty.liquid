<section class="shop-page">
  {% assign featured_product = all_products['producto-digital'] %}
  {% if featured_product == blank %}
    {% assign featured_product = all_products['stop-being-broke'] %}
  {% endif %}
  {% assign home_collection = collections['home-page'] %}
  {% if featured_product == blank and home_collection.products_count > 0 %}
    {% assign featured_product = home_collection.products.first %}
  {% endif %}
  <div class="page-intro">
    <p class="eyebrow">Digital resources</p>
    <h1>Guide Market Store</h1>
    <p>Browse official Guide Market digital resources.</p>
  </div>

  {% if collection.products_count > 0 %}
    <div class="product-grid">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% elsif home_collection.products_count > 0 %}
    <div class="product-grid">
      {% for product in home_collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% else %}
    {% if featured_product != blank %}
      <div class="product-grid single">
        {% render 'product-card', product: featured_product %}
      </div>
    {% else %}
      <div class="vault-card centered" aria-label="Guide Market products">
        <span class="lock">Store catalog</span>
        <h2>Add your product to the Online Store channel.</h2>
        <p>Once Stop Being Broke is published in Shopify, it will appear here automatically.</p>
        <div class="placeholder-grid six" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <a class="button" href="{{ routes.root_url }}">Back to home</a>
      </div>
    {% endif %}
  {% endif %}

  <div class="store-sections compact" aria-label="Store sections">
    <div class="empty-section">
      <div>
        <p class="eyebrow">Top Sales</p>
        <h3>Featured digital resource.</h3>
        <p>The current storefront keeps attention on the main product.</p>
      </div>
      <div class="placeholder-grid six" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
      <span class="lock">Active section</span>
    </div>

    <div class="empty-section">
      <div>
        <p class="eyebrow">Reviews</p>
        <h3>Customer notes and feedback.</h3>
        <p>Use this area for verified customer reviews as they arrive.</p>
      </div>
      <div class="placeholder-grid" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <span class="lock">Review area</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop collection",
  "settings": []
}
{% endschema %}
