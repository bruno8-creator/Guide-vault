<section class="shop-page">
  {% assign featured_product = all_products['producto-digital'] %}
  {% if featured_product == blank %}
    {% assign featured_product = all_products['stop-being-broke'] %}
  {% endif %}
  {% assign home_collection = collections['home-page'] %}
  {% if featured_product == blank and home_collection.products_count > 0 %}
    {% assign featured_product = home_collection.products.first %}
  {% endif %}
  <div class="page-intro">
    <p class="eyebrow">Digital resources</p>
    <h1>Guide Market Store</h1>
    <p>Browse official Guide Market releases as they become available.</p>
  </div>

  {% if collection.products_count > 0 %}
    <div class="product-grid">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% elsif home_collection.products_count > 0 %}
    <div class="product-grid">
      {% for product in home_collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% else %}
    {% if featured_product != blank %}
      <div class="product-grid single">
        {% render 'product-card', product: featured_product %}
      </div>
    {% else %}
      <div class="vault-card centered" aria-label="Products coming soon">
        <span class="lock">Digital releases in progress</span>
        <h2>Products coming soon.</h2>
        <p>Guide Market is preparing its first digital releases. Join the waitlist to be notified when the store opens.</p>
        <div class="placeholder-grid six" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <a class="button" href="/pages/contact">Join the Waitlist</a>
      </div>
    {% endif %}
  {% endif %}

  <div class="store-sections compact" aria-label="Prepared empty store sections">
    <div class="empty-section">
      <div>
        <p class="eyebrow">Top Sells</p>
        <h3>Top sells will appear after launch.</h3>
        <p>Reserved for real store data once Guide Market has active digital releases and verified performance.</p>
      </div>
      <div class="placeholder-grid six" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
      <span class="lock">Coming Soon</span>
    </div>

    <div class="empty-section">
      <div>
        <p class="eyebrow">Reviews</p>
        <h3>Verified reviews are coming later.</h3>
        <p>Customer feedback will be shown only after real purchases or verified product experiences exist.</p>
      </div>
      <div class="placeholder-grid" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <span class="lock">Coming Soon</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop collection",
  "settings": []
}
{% endschema %}
