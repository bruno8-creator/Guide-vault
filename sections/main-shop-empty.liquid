<section class="shop-page">
  <div class="page-intro">
    <p class="eyebrow">Digital resources coming soon.</p>
    <h1>Guidora Store</h1>
    <p>The store is being prepared. New digital releases will be added soon.</p>
  </div>

  <div class="vault-card centered" aria-label="Products coming soon">
    <span class="lock">Digital releases in progress</span>
    <h2>Products coming soon.</h2>
    <p>Guidora is preparing its first digital releases. Join the waitlist to be notified when the store opens.</p>
    <div class="placeholder-grid six" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
    <a class="button" href="/pages/contact">Join the Waitlist</a>
  </div>

  <div class="store-sections compact" aria-label="Prepared empty store sections">
    <div class="empty-section">
      <div>
        <p class="eyebrow">Top Sells</p>
        <h3>Top sells will appear after launch.</h3>
        <p>Reserved for real store data once Guidora has active digital releases and verified performance.</p>
      </div>
      <div class="placeholder-grid six" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
      <span class="lock">Coming Soon</span>
    </div>

    <div class="empty-section">
      <div>
        <p class="eyebrow">Reviews</p>
        <h3>Verified reviews are coming later.</h3>
        <p>Customer feedback will be shown only after real purchases or verified product experiences exist.</p>
      </div>
      <div class="placeholder-grid" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <span class="lock">Coming Soon</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Empty shop page",
  "settings": []
}
{% endschema %}
