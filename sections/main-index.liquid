{% assign featured_product = all_products['stop-being-broke'] %}
{% if featured_product == blank %}
  {% assign featured_product = all_products['producto-digital'] %}
{% endif %}
{% if featured_product == blank and collections['home-page'].products_count > 0 %}
  {% assign featured_product = collections['home-page'].products.first %}
{% endif %}
{% assign top_sales_collection = collections['all'] %}
{% assign drained_product = all_products['stop-feeling-drained'] %}
{% if drained_product == blank %}
  {% assign drained_product = all_products['stop-feeling-drained-ai'] %}
{% endif %}
{% if drained_product == blank and collections['home-page'].products_count > 0 %}
  {% for product_item in collections['home-page'].products %}
    {% assign product_title_downcase = product_item.title | downcase %}
    {% if product_title_downcase contains 'stop feeling drained' %}
      {% assign drained_product = product_item %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}
{% if drained_product == blank and collections['all'].products_count > 0 %}
  {% for product_item in collections['all'].products %}
    {% assign product_title_downcase = product_item.title | downcase %}
    {% if product_title_downcase contains 'stop feeling drained' %}
      {% assign drained_product = product_item %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

<section class="home-hero" data-brand="Guide Market">
  <div class="glow glow-emerald"></div>
  <div class="glow glow-gold"></div>
  <div class="hero-content">
    <p class="eyebrow">Premium digital store</p>
    <img class="hero-logo" src="{{ 'guide-market-logo.svg' | asset_url }}" alt="Guide Market">
    <h1>Guide Market</h1>
    <p class="lede">Premium digital guides for people who want clearer habits, better decisions, and a simple plan they can actually follow.</p>
    <div class="actions">
      <a class="button" href="#top-sales">Shop digital guides</a>
      <a class="button secondary" href="#finance">Explore finance</a>
    </div>
    <div class="hero-trust-row" aria-label="Store benefits">
      <span>Instant access</span>
      <span>Mobile friendly</span>
      <span>Clear action steps</span>
    </div>
  </div>
</section>

<section class="trust-strip" aria-label="Guide Market benefits">
  <div class="trust-item">
    <strong>Quick to start</strong>
    <span>No complicated setup. Open the guide and begin.</span>
  </div>
  <div class="trust-item">
    <strong>Built for action</strong>
    <span>Short, practical sections made for real-life use.</span>
  </div>
  <div class="trust-item">
    <strong>Clean digital format</strong>
    <span>Designed to be easy to read on phone or desktop.</span>
  </div>
</section>

<section id="top-sales" class="content-band top-sales-section">
  <div class="section-heading centered">
    <p class="eyebrow">TOP SALES</p>
    <h2>Choose the guide that fits your next move.</h2>
    <p>Focused digital products with clear steps, useful structure, and no unnecessary filler.</p>
  </div>

  {% if top_sales_collection.products_count > 0 %}
    <div class="top-sales-feature">
      {% for product_item in top_sales_collection.products limit: 8 %}
        {% render 'product-card', product: product_item %}
      {% endfor %}
    </div>
  {% elsif featured_product != blank or drained_product != blank %}
    <div class="top-sales-feature">
      {% if featured_product != blank %}
        {% render 'product-card', product: featured_product %}
      {% endif %}
      {% if drained_product != blank %}
        {% render 'product-card', product: drained_product %}
      {% endif %}
    </div>
  {% else %}
    <div class="empty-section">
      <div>
        <p class="eyebrow">TOP SALES</p>
        <h3>Add your products to Shopify.</h3>
        <p>When products are published to the Online Store channel, they will appear here automatically.</p>
      </div>
      <div class="placeholder-grid" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>
  {% endif %}
</section>

<section class="content-band offer-section" aria-label="Why buy from Guide Market">
  <div class="section-heading centered">
    <p class="eyebrow">Why Guide Market</p>
    <h2>Simple guides. Clear outcomes.</h2>
    <p>Each product is built to help you understand the problem, make a plan, and take the next step with less friction.</p>
  </div>
  <div class="offer-grid">
    <article class="offer-card">
      <span>01</span>
      <h3>Less overwhelm</h3>
      <p>Direct explanations and clean structure so customers know exactly where to start.</p>
    </article>
    <article class="offer-card">
      <span>02</span>
      <h3>Better daily decisions</h3>
      <p>Guidance focused on practical choices, habits, and routines people can use right away.</p>
    </article>
    <article class="offer-card">
      <span>03</span>
      <h3>Premium feel</h3>
      <p>A polished digital reading experience that feels intentional, not thrown together.</p>
    </article>
  </div>
</section>

<section id="finance" class="content-band finance-section">
  <div class="section-heading">
    <p class="eyebrow">Finance</p>
    <h2>Money tools without the noise.</h2>
    <p>Start with the core resource, then build better systems around how you earn, spend, and plan.</p>
  </div>

  <div class="finance-layout">
    <div class="finance-copy">
      <span class="lock">Focused category</span>
      <h3>Stop Being Broke</h3>
      <p>Designed for people who want simple, direct finance guidance they can use immediately.</p>
      {% if featured_product != blank %}
        <a class="button secondary" href="{{ featured_product.url }}">Open finance product</a>
      {% endif %}
    </div>
    {% if featured_product != blank %}
      <div class="finance-product-mini">
        {% render 'product-card', product: featured_product %}
      </div>
    {% endif %}
  </div>
</section>

<section class="content-band buying-section" aria-label="How buying works">
  <div class="buying-panel">
    <div>
      <p class="eyebrow">How it works</p>
      <h2>Buy once. Start immediately.</h2>
      <p>Pick a guide, complete checkout, and use the digital resource at your own pace.</p>
    </div>
    <div class="buying-steps">
      <span>Choose your guide</span>
      <span>Checkout securely</span>
      <span>Start reading</span>
    </div>
    <a class="button" href="#top-sales">See products</a>
  </div>
</section>

<section class="content-band reviews-section" aria-label="Business reviews">
  <div class="section-heading centered">
    <p class="eyebrow">Customer Notes</p>
    <h2>Early reader-style feedback.</h2>
    <p>Promotional sample reviews for the brand voice. Replace these with verified Shopify reviews once real customers leave feedback.</p>
  </div>
  <div class="review-grid">
    <article class="review-card">
      <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
      <p>"Clean, direct, and actually useful. It makes personal finance feel less overwhelming."</p>
      <strong>Alex R.</strong>
    </article>
    <article class="review-card">
      <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
      <p>"The structure is simple enough to follow, but polished enough to feel premium."</p>
      <strong>Maya S.</strong>
    </article>
    <article class="review-card">
      <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
      <p>"A strong first resource for anyone trying to get serious about money habits."</p>
      <strong>Jordan L.</strong>
    </article>
  </div>
</section>

{% schema %}
{
  "name": "Guide Market home",
  "settings": []
}
{% endschema %}
