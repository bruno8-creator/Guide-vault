<section class="hero">
  <div class="glow glow-emerald"></div>
  <div class="glow glow-gold"></div>
  <div class="hero-content">
    <p class="eyebrow">Premium digital store</p>
    <h1>Guidora</h1>
    <p class="lede">Premium digital resources designed for clarity, structure, and action.</p>
    <div class="actions">
      <a class="button" href="/pages/contact">Join Waitlist</a>
      <a class="button secondary" href="#store-preview">Explore the Store</a>
    </div>
  </div>
  <div id="store-preview" class="vault-card" aria-label="Products coming soon">
    <span class="lock">Locked</span>
    <h2>Products coming soon.</h2>
    <p>Guidora is preparing its first digital releases. Join the waitlist to be notified when the store opens.</p>
  </div>
</section>

{% assign featured_product = all_products['producto-digital'] %}
{% if featured_product == blank %}
  {% assign featured_product = all_products['stop-being-broke'] %}
{% endif %}
{% if featured_product == blank and collections['home-page'].products_count > 0 %}
  {% assign featured_product = collections['home-page'].products.first %}
{% endif %}
<section class="content-band featured-product-band">
  <div class="section-heading">
    <p class="eyebrow">Featured Release</p>
    <h2>Now added to Guidora.</h2>
    <p>
      This section pulls from your real Shopify product. It checks the public product handle and
      the Home page collection shown in Shopify Admin.
    </p>
  </div>

  {% if featured_product != blank %}
    <div class="featured-product-layout">
      {% render 'product-card', product: featured_product %}
      <div class="featured-copy">
        <span class="lock">Real Shopify Product</span>
        <h3>{{ featured_product.title }}</h3>
        {% if featured_product.description != blank %}
          <div class="rte">{{ featured_product.description | truncatewords: 34 }}</div>
        {% else %}
          <p>Details for this digital resource can be completed in Shopify Admin.</p>
        {% endif %}
        <a class="button" href="{{ featured_product.url }}">View product</a>
      </div>
    </div>
  {% else %}
    <div class="empty-section">
      <div>
        <p class="eyebrow">Product not visible yet</p>
        <h3>Publish the product to Online Store.</h3>
        <p>
          Once the product is active and available on the Online Store sales channel, it will render
          here automatically.
        </p>
      </div>
      <div class="placeholder-grid" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <span class="lock">Waiting for Shopify</span>
    </div>
  {% endif %}
</section>

<section class="content-band">
  <div class="section-heading">
    <p class="eyebrow">Brand Value</p>
    <h2>Built for clarity. Designed for action.</h2>
    <p>
      Guidora is being built as a premium home for practical digital resources. The focus is
      simple: clean design, useful structure, and tools that help people take action.
    </p>
  </div>
  <div class="card-grid three">
    <article class="info-card">
      <h3>Clear</h3>
      <p>Simple layouts, direct information, and a clean user experience.</p>
    </article>
    <article class="info-card">
      <h3>Practical</h3>
      <p>Resources designed to be used, not just read.</p>
    </article>
    <article class="info-card">
      <h3>Premium</h3>
      <p>A polished digital experience built with attention to detail.</p>
    </article>
  </div>
</section>

<section class="content-band">
  <div class="section-heading">
    <p class="eyebrow">Future Categories</p>
    <h2>What Guidora will offer</h2>
  </div>
  <div class="card-grid four">
    <article class="info-card">
      <span class="lock">Coming Soon</span>
      <h3>Ebooks</h3>
      <p>Structured digital reading experiences for focused learning.</p>
    </article>
    <article class="info-card">
      <span class="lock">Coming Soon</span>
