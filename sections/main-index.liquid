<section class="hero">
  <div class="glow glow-emerald"></div>
  <div class="glow glow-gold"></div>
  <div class="hero-content">
    <p class="eyebrow">Premium digital store</p>
    <h1>Guidora</h1>
    <p class="lede">Premium digital resources designed for clarity, structure, and action.</p>
    <div class="actions">
      <a class="button" href="/pages/contact">Join Waitlist</a>
      <a class="button secondary" href="#store-preview">Explore the Store</a>
    </div>
  </div>
  <div id="store-preview" class="vault-card" aria-label="Products coming soon">
    <span class="lock">Locked</span>
    <h2>Products coming soon.</h2>
    <p>Guidora is preparing its first digital releases. Join the waitlist to be notified when the store opens.</p>
  </div>
</section>

<section class="content-band">
  <div class="section-heading">
    <p class="eyebrow">Brand Value</p>
    <h2>Built for clarity. Designed for action.</h2>
    <p>
      Guidora is being built as a premium home for practical digital resources. The focus is
      simple: clean design, useful structure, and tools that help people take action.
    </p>
  </div>
  <div class="card-grid three">
    <article class="info-card">
      <h3>Clear</h3>
      <p>Simple layouts, direct information, and a clean user experience.</p>
    </article>
    <article class="info-card">
      <h3>Practical</h3>
      <p>Resources designed to be used, not just read.</p>
    </article>
    <article class="info-card">
      <h3>Premium</h3>
      <p>A polished digital experience built with attention to detail.</p>
    </article>
  </div>
</section>

<section class="content-band">
  <div class="section-heading">
    <p class="eyebrow">Future Categories</p>
    <h2>What Guidora will offer</h2>
  </div>
  <div class="card-grid four">
    <article class="info-card">
      <span class="lock">Coming Soon</span>
      <h3>Ebooks</h3>
      <p>Structured digital reading experiences for focused learning.</p>
    </article>
    <article class="info-card">
      <span class="lock">Coming Soon</span>
      <h3>Digital Guides</h3>
      <p>Step-by-step resources designed to make complex ideas easier to use.</p>
    </article>
    <article class="info-card">
      <span class="lock">Coming Soon</span>
      <h3>Printable Templates</h3>
      <p>Clean layouts for planning, organizing, and making progress.</p>
    </article>
    <article class="info-card">
      <span class="lock">Coming Soon</span>
      <h3>Practical Toolkits</h3>
      <p>Digital systems and resources built for action.</p>
    </article>
  </div>
</section>

<section class="store-sections" aria-label="Future store sections">
  <div class="section-heading">
    <p class="eyebrow">Store layout</p>
    <h2>More store sections are ready, but intentionally empty.</h2>
    <p>
      These blocks are placeholders for real future activity. They add structure without inventing
      products, prices, testimonials, or performance numbers.
    </p>
  </div>

  <div class="empty-section">
    <div>
      <p class="eyebrow">Top Sells</p>
      <h3>Top sells will appear after launch.</h3>
      <p>Reserved for real store data once Guidora has active digital releases and verified performance.</p>
    </div>
    <div class="placeholder-grid six" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
    <span class="lock">Coming Soon</span>
  </div>

  <div class="empty-section">
    <div>
      <p class="eyebrow">New Arrivals</p>
      <h3>New digital releases will be listed here.</h3>
      <p>This area is prepared for future launches and remains empty until real resources are added.</p>
    </div>
    <div class="placeholder-grid six" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
    <span class="lock">Coming Soon</span>
  </div>

  <div class="empty-section">
    <div>
      <p class="eyebrow">Reviews</p>
      <h3>Verified reviews are coming later.</h3>
      <p>Customer feedback will be shown only after real purchases or verified product experiences exist.</p>
    </div>
    <div class="placeholder-grid" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <span class="lock">Coming Soon</span>
  </div>

  <div class="empty-section">
    <div>
      <p class="eyebrow">Launch Updates</p>
      <h3>Store updates will be posted here.</h3>
      <p>Future announcements, release notes, and launch windows can be placed in this area.</p>
    </div>
    <div class="placeholder-grid" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <span class="lock">Coming Soon</span>
  </div>

  <div class="waitlist-panel">
    <p class="eyebrow">Updates</p>
    <h2>Join before the store opens.</h2>
    <p>Get notified when Guidora publishes its first official digital releases.</p>
    <a class="button" href="/pages/contact">Join Waitlist</a>
  </div>
</section>

{% schema %}
{
  "name": "Guidora coming soon home",
  "settings": []
}
{% endschema %}
