<section class="cart-page">
  <div class="page-intro">
    <p class="eyebrow">Guidora checkout</p>
    <h1>Your cart</h1>
    <p>Review your selected digital resources before continuing to checkout.</p>
  </div>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" class="cart-panel">
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <a class="cart-item-media" href="{{ item.url }}">
              {% if item.image %}
                {{
                  item.image
                  | image_url: width: 360
                  | image_tag:
                    loading: 'lazy',
                    widths: '180, 240, 360',
                    sizes: '120px',
                    alt: item.image.alt | default: item.product.title | escape
                }}
              {% else %}
                <span>Guidora</span>
              {% endif %}
            </a>
            <div class="cart-item-info">
              <h2><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
              {% unless item.variant.title == 'Default Title' %}
                <p class="cart-variant">{{ item.variant.title }}</p>
              {% endunless %}
              <p class="product-price">{{ item.final_line_price | money }}</p>
              <label>
                Quantity
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </label>
              <a class="cart-remove" href="{{ item.url_to_remove }}">Remove</a>
            </div>
          </div>
        {% endfor %}
      </div>

      <aside class="cart-summary">
        <p class="eyebrow">Summary</p>
        <div class="summary-line">
          <span>Subtotal</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <p class="variant-help">
          Taxes, discounts, and payment methods are calculated by Shopify at checkout.
        </p>
        <div class="purchase-actions">
          <button class="button secondary" type="submit" name="update">Update cart</button>
          <button class="button buy-button" type="submit" name="checkout">Checkout</button>
        </div>
      </aside>
    </form>
  {% else %}
    <div class="vault-card centered">
      <span class="lock">Empty cart</span>
      <h2>Your cart is empty.</h2>
      <p>Add a Guidora digital resource before continuing to checkout.</p>
      <a class="button" href="/collections/all">Browse store</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
